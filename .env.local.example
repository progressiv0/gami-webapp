# Copy this file to .env.local and fill in values

# SQLite database path (relative to project root)
DATABASE_PATH=./gami.db

# Secret for iron-session cookie encryption — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-secret-before-production

# URL of the running gami-api (Go server)
GAMI_API_URL=http://localhost:8080

# Folder where GPR JSON files are synced to disk
GPR_STORE_DIR=./gpr-store
